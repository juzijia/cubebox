# ==========================================
# 3. 正则匹配 (DOMAIN-REGEX)
# ⚠️ 仅限 Clash Meta (Mihomo) 内核使用
# ==========================================
# NTP 时间同步
DOMAIN-REGEX,^time\.[^.]+\.com
DOMAIN-REGEX,^time\.[^.]+\.gov
DOMAIN-REGEX,^time\.[^.]+\.edu\.cn
DOMAIN-REGEX,^time\.[^.]+\.apple\.com
DOMAIN-REGEX,^time[1-7]\.[^.]+\.com
DOMAIN-REGEX,^ntp\.[^.]+\.com
DOMAIN-REGEX,^ntp[1-7]\.[^.]+\.com
DOMAIN-REGEX,^[^.]+\.time\.edu\.cn
DOMAIN-REGEX,^[^.]+\.ntp\.org\.cn

  # STUN / TURN 穿透
DOMAIN-REGEX,^(.+\.)?stun\.[^.]+\.[^.]+$
DOMAIN-REGEX,^(.+\.)?stun\.[^.]+\.[^.]+\.[^.]+$
DOMAIN-REGEX,^(.+\.)?stun\.[^.]+\.[^.]+\.[^.]+\.[^.]+$
DOMAIN-REGEX,^(.+\.)?stun\.[^.]+\.[^.]+\.[^.]+\.[^.]+\.[^.]+$
DOMAIN-REGEX,^turn\..+
DOMAIN-REGEX,^(.+\.)?turn\..+

  # PT Tracker / P2P
DOMAIN-REGEX,^tracker\.
DOMAIN-REGEX,^announce\.
DOMAIN-REGEX,^(.+\.)?tracker\.[^.]+\.[^.]+$
DOMAIN-REGEX,^(.+\.)?announce\.[^.]+\.[^.]+$
DOMAIN-REGEX,^dht\.
DOMAIN-REGEX,^p2p\.
DOMAIN-REGEX,^bt\.
  
  # 其他
DOMAIN-REGEX,^localhost\.[^.]+\.weixin\.qq\.com
DOMAIN-REGEX,^[^.]+\.n\.n\.srv\.nintendo\.net
DOMAIN-REGEX,^xbox\.[^.]+\.[^.]+\.microsoft\.com
DOMAIN-REGEX,^[^.]+\.[^.]+\.xboxlive\.com
DOMAIN-REGEX,^xbox\.[^.]+\.microsoft\.com
